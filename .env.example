# Environment Variables — SMB Backend

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/smb_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (SMTP) ──────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_FROM="SMB Store <noreply@yourdomain.com>"

# ── CRM Integration ───────────────────────────────────────
CRM_PROVIDER=hubspot           # hubspot | salesforce | pipedrive | none
CRM_API_KEY=your_crm_api_key
CRM_BASE_URL=https://api.hubapi.com

# ── App ───────────────────────────────────────────────────
PORT=4001
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
