// SMB E-Commerce — Prisma Schema
// Database:  PostgreSQL 16
// ORM:       Prisma 5
//
// Conventions (mirrors BangMe approach):
//   - Table names:   snake_case, plural  (@map)
//   - Column names:  snake_case          (@map)
//   - Primary keys:  UUID v4             (@default(uuid()))
//   - Money values:  DECIMAL(12,2)       (@db.Decimal(12,2))  — never Float
//   - Timestamps:    UTC, every table has created_at + updated_at
//   - Soft deletes:  deleted_at on users and products
//   - Enum values:   SCREAMING_SNAKE_CASE

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum CrmSyncStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid())
  email        String    @unique @db.VarChar(255)
  passwordHash String?   @map("password_hash")
  name         String?   @db.VarChar(100)
  phone        String?   @db.VarChar(30)
  companyName  String?   @map("company_name") @db.VarChar(200)
  role         Role      @default(CUSTOMER)
  isGuest      Boolean   @default(false) @map("is_guest")
  isVerified   Boolean   @default(false) @map("is_verified")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  orders    Order[]
  addresses Address[]
  sessions  Session[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model Product {
  id          String    @id @default(uuid())
  name        String    @db.VarChar(200)
  slug        String    @unique @db.VarChar(200)
  description String?
  price       Decimal   @db.Decimal(12, 2)
  stock       Int       @default(0)
  images      String[]
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  orderItems OrderItem[]

  @@index([slug])
  @@index([isActive, createdAt(sort: Desc)])
  @@map("products")
}

model Order {
  id              String      @id @default(uuid())
  userId          String?     @map("user_id")
  user            User?       @relation(fields: [userId], references: [id])
  guestEmail      String?     @map("guest_email") @db.VarChar(255)
  guestName       String?     @map("guest_name") @db.VarChar(100)
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  stripePaymentId String?     @unique @map("stripe_payment_id")
  stripeSessionId String?     @unique @map("stripe_session_id")
  shippingAddress Json?       @map("shipping_address")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  items      OrderItem[]
  crmSyncLog CrmSyncLog?

  @@index([userId])
  @@index([status, createdAt(sort: Desc)])
  @@index([stripeSessionId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String  @map("product_id")
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@map("order_items")
}

model Address {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String  @db.VarChar(100)
  street    String  @db.VarChar(255)
  city      String  @db.VarChar(100)
  state     String? @db.VarChar(100)
  country   String  @db.VarChar(100)
  zip       String  @db.VarChar(20)
  isDefault Boolean @default(false) @map("is_default")

  @@index([userId])
  @@map("addresses")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model CrmSyncLog {
  id            String        @id @default(uuid())
  orderId       String        @unique @map("order_id")
  order         Order         @relation(fields: [orderId], references: [id])
  crmName       String        @map("crm_name") @db.VarChar(50)
  status        CrmSyncStatus @default(PENDING)
  attempts      Int           @default(0)
  lastAttemptAt DateTime?     @map("last_attempt_at")
  errorMessage  String?       @map("error_message")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@index([status])
  @@map("crm_sync_logs")
}
